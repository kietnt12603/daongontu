# Cấu hình Cổng chạy Backend NestJS
PORT=3001

# Khóa bí mật dùng mã hóa JWT token
JWT_SECRET=daongontusecretkeyjwt12345!
JWT_EXPIRES_IN=7d

# URL kết nối cơ sở dữ liệu Postgres cục bộ (Chạy trực tiếp từ npx prisma dev, ép kết nối qua IPv4 127.0.0.1)
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:51214/template1?sslmode=disable&connection_limit=10&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0"